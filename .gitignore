# Backend
backend/target/
backend/src/main/resources/application-local.yml

# Docker Compose local env (do not commit real secrets)
.env

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env*
!frontend/.env.example
frontend/.env.local

# Playwright
.playwright-cli/

# Logs
*.log

# Runtime outputs
output/runtime/
output/screenshots/dev/.artifacts/
output/playwright/
output/*.txt

# Thesis assembled artifacts (regenerated by build-docx.ps1, not hand-maintained)
thesis-assets/current/

# Office temporary lock files
~$*.docx
~$*.xlsx
~$*.pptx
*.tmp

# Local review bundles and one-off backups
thesis_literature_enhancement_package.zip
thesis-assets/*.before-literature.*

# Eclipse project metadata
backend/.classpath
backend/.factorypath
backend/.project
backend/.settings/
output/screenshots/dev/

# sentrux structural-gate baseline (regenerated locally with
# `sentrux gate --save`; not part of the canonical repo state).
.sentrux/baseline.json

# Workspace-local Playwright browser cache. Mirrors the
# `PLAYWRIGHT_BROWSERS_PATH=${{ github.workspace }}/.cache/ms-playwright`
# setting in .github/workflows/ci.yml — local devs who copy that env var
# for parity with CI get a gitignored, ephemeral cache directory.
.cache/
