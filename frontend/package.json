{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vue-tsc --noEmit && vp build",
    "check": "vp check",
    "test:contracts": "node --test tests/interview/session-preferences.test.ts tests/report/resume-improvement-contract.test.ts tests/settings/provider-contract.test.ts",
    "verify:architecture": "node --test tests/architecture/verify-architecture.test.cjs && node scripts/verify-architecture.cjs",
    "verify:production": "node --test tests/architecture/verify-production-bundle.test.cjs && node scripts/verify-production-bundle.cjs",
    "verify:flows": "playwright test -c playwright.flow.config.ts",
    "preview": "vp preview",
    "capture:local": "playwright test -c playwright.local.config.ts",
    "verify:byok": "node scripts/verify-byok-settings-flow.cjs",
    "verify:dark": "node scripts/verify-dark-theme-flow.cjs",
    "verify:ui": "node scripts/verify-ui-guardrails.cjs",
    "capture:visual": "playwright test -c playwright.visual.config.ts",
    "verify:visual": "playwright test -c playwright.visual.config.ts",
    "verify:a11y": "playwright test -c playwright.a11y.config.ts",
    "verify:tokens": "node scripts/verify-ui-tokens.cjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@paper-design/shaders-react": "^0.0.76",
    "@tailwindcss/vite": "^4.3.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "markdown-it": "^14.2.0",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reka-ui": "^2.9.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.32",
    "vue-router": "^4.6.1",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.56.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "form-data": "4.0.6",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.6.0"
}
