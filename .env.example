# =============================================================================
# Prelude Docker Compose 环境变量模板
# -----------------------------------------------------------------------------
# .env 已被 .gitignore 忽略，不要提交真实密钥。
# start-dev.bat 仅使用中间件配置；start-docker.bat 使用该文件进行 Full Docker / 部署验证。
# =============================================================================

# ---- 宿主机端口映射（默认值已避开本机 MySQL/Redis 原生端口，避免冲突） ----
# 宿主机访问中间件时用这些端口；容器内部互访仍用默认端口（mysql:3306 等）。
MYSQL_HOST_PORT=13306
REDIS_HOST_PORT=16379
RABBITMQ_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HOST_PORT=15672

# ---- 中间件凭据 ----
MYSQL_ROOT_PASSWORD=root_password

# ---- 应用密钥（生产请替换为强随机值，至少 32 字节） ----
JWT_SECRET=replace-with-at-least-32-bytes-jwt-secret
APP_CRYPTO_AES_SECRET=replace-with-at-least-32-bytes-aes-secret

# ---- 内置 LLM Provider（可选；推荐在前端设置页用 BYOK 配置用户级模型） ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=
