flowchart TB
  fe_send[" &nbsp; 前端：发送 /chat 请求 &nbsp; "]
  
  be_emitter[" &nbsp; 后端：建立 SseEmitter &nbsp; "]
  be_context[" &nbsp; 后端：组装上下文 &nbsp; "]
  
  llm_stream[" &nbsp; 模型：流式输出 &nbsp; "]
