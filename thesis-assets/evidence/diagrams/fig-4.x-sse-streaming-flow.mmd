  fe_send --> be_emitter --> be_context
  
  be_context --> llm_stream
  be_emitter --> be_push
  
  llm_stream --> be_push
  be_push --> fe_render
  fe_render --> check_done
  
  check_done -- "否" --> llm_stream
  check_done -- "是" --> db_save
  check_done -- "是" --> fe_finish

