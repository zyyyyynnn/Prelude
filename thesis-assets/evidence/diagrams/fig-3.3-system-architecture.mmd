flowchart TB
  user((" &nbsp; 用户 / 浏览器端 &nbsp; "))

  subgraph frontend["<div style='width: 500px; text-align: left;'>前端功能模块</div>"]
    direction LR
    vue[" &nbsp; Vue 3 / Vite &nbsp; "]
    features[" &nbsp; auth / resume / interview / report / insight / settings &nbsp; "]
  end

  subgraph backend[" &nbsp; Spring Boot 模块化单体 &nbsp; "]
    direction TB
    api[" &nbsp; API 适配层 &nbsp; <br/> &nbsp; Controller / Request / Response 映射 &nbsp; "]
    application[" &nbsp; 应用层 &nbsp; <br/> &nbsp; Use Case / Command / Result / View &nbsp; "]
    domain[" &nbsp; 领域模块 &nbsp; <br/> &nbsp; identity / resume / interview / insight / catalog &nbsp; "]
    ports[" &nbsp; 端口边界 &nbsp; <br/> &nbsp; Chat / Retrieval / Job / Realtime / Repository &nbsp; "]
    infrastructure[" &nbsp; 基础设施适配层 &nbsp; <br/> &nbsp; MyBatis / Redis / HTTP / SSE / WebSocket &nbsp; <br/> &nbsp; ReportJobWorker &nbsp; "]
  end

  subgraph runtime[" &nbsp; 数据与外部运行依赖 &nbsp; "]
    direction LR
    mysql[" &nbsp; MySQL &nbsp; <br/> &nbsp; 业务数据 &nbsp; "]
    redis[" &nbsp; Redis &nbsp; <br/> &nbsp; 限流 / 缓存 / 状态辅助 &nbsp; "]
    rabbit[" &nbsp; RabbitMQ &nbsp; <br/> &nbsp; 报告任务队列 &nbsp; "]
    llm[" &nbsp; LLM Provider &nbsp; <br/> &nbsp; DeepSeek + 3 BYOK protocols &nbsp; "]
    mysql ~~~ redis ~~~ rabbit ~~~ llm
  end

  fixture[" &nbsp; 本地验收数据夹具 &nbsp; <br/> &nbsp; local/dev only &nbsp; "]
  monitor[" &nbsp; Prometheus / Grafana &nbsp; <br/> &nbsp; 可选观测层 &nbsp; "]

  user --> vue
  vue --> features
  features --> api

  api --> application
  application --> domain
  application --> ports
  infrastructure -->|implements| ports
  infrastructure --> runtime

  fixture -.-> application
  fixture -.-> runtime
  monitor -.-> api

